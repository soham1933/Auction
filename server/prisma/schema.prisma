generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model PlayerImage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  playerId  String   @unique @db.ObjectId
  imageUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([playerId])
}

